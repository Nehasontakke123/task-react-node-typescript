{
  "name": "task-react-node-typescript",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w server && npm run build -w client",
    "install:all": "npm install --workspaces --include-workspace-root --offline=false --prefer-online"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
